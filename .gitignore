# BRiCk workspace (SkyLabsAI/workspace meta-repo, built locally by
# scripts/setup-brick-workspace.sh). Match both a real directory and a symlink
# pointing at a workspace elsewhere on disk.
.brick-workspace/
.brick-workspace

# Local opam switch (created by the setup script)
_opam/

# Coq build artifacts
coq/*.vo
coq/*.vok
coq/*.vos
coq/*.glob
coq/.*.aux
coq/Makefile.coq
coq/Makefile.coq.conf
coq/.Makefile.coq.d

# Coq arithmetic cache
.lia.cache

# cpp2v-generated files (regenerated by `make cpp2v`)
coq/map_int_int_cpp.v
coq/map_int_int_cpp_names.v

# Lean build artifacts
lean/.lake/
lean/build/

# macOS
.DS_Store

# Local MCP client config (machine-specific absolute paths; see BUILDING.md)
.mcp.json
