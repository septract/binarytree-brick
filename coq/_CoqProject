# Coq/Rocq project file for the Daedalus RB tree BRiCk verification.
#
# The generated files (map_int_int_cpp.v, map_int_int_cpp_names.v) are
# produced by cpp2v and must exist before building. Run `make cpp2v`
# from the repository root first.
#
# The canonical build is driven by the top-level Makefile. This file is
# provided for editor / IDE integration (e.g. VsCoq, Proof General).

-R . daedalus_rb

# Generated by cpp2v (must exist before building)
map_int_int_cpp_names.v
map_int_int_cpp.v

# Generic weakest-precondition tactic library (no tree/AST dependencies)
WpTactics.v

# Functional specification (ported from lean/Rbtree/Daedalus.lean)
RBTree.v

# Separation-logic representation predicate
TreeRep.v

# Tree-specific tactics and lemmas
Tactics.v

# Operation specifications and proofs
FindSpec.v
InsertDefs.v
InsertSpec.v
IsBlackSpec.v
RebalanceDefs.v
SetRebalanceLeft.v
SetRebalanceRight.v
InsSpec.v
RefCount.v
Invariants.v
