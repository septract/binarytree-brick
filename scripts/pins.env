# Known-good commit pins for the BRiCk toolchain used to check these proofs.
#
# The SkyLabsAI/workspace meta-repo clones its sub-repositories at MOVING
# branch heads (main / skylabs-master), so a plain clone will drift over time
# and may break against these proofs. The pins below record the exact commits
# that the proofs were last checked against. `setup-brick-workspace.sh` checks
# these out after cloning.
#
# Captured: 2026-07-07 (from a working local build; Rocq 9.1.0, OCaml 5.4.0).
# To refresh: rebuild against newer heads, re-run the proofs, then update here.

# Meta-repo (SkyLabsAI/workspace)
WORKSPACE_REPO="https://github.com/SkyLabsAI/workspace.git"
WORKSPACE_COMMIT="083d841629c37b20c1e6dd290a12663f9f030bdf"

# fmdeps/ — the FM libraries (BRiCk itself + support)
PIN_fmdeps_BRiCk="e2f29ae00918a8397475b86f0b6be9ce53c006af"
PIN_fmdeps_brick_libcpp="53842f7b095a333319aec07f1b5cf2ab33556789"
PIN_fmdeps_auto_docs="e83c1adecfc0f1ea0ac6bce66f8a809f14c78946"
PIN_fmdeps_fm_ci="e97f125ed66ea6ed203f9255ebdc8658c892c96a"

# vendored/ — Rocq prover + libraries, built from source
PIN_vendored_rocq="2ede3c94550bf51b2d16ef6c938cf04a28bf3113"
PIN_vendored_rocq_stdlib="bc07423a95ca26b31574b08da9dc60fee4943dab"
PIN_vendored_rocq_stdpp="e01d802a8ab22739eb3dfe225d98041ab571ed6d"
PIN_vendored_rocq_iris="3ad4ddd387365ee9bfffa65975012be6d43f7322"
PIN_vendored_rocq_elpi="103a74218f44538bb7eab3827e3af48d328cc276"
PIN_vendored_elpi="aa4475f75da6882345900785c776685eb66f45df"
PIN_vendored_rocq_equations="a8c483204326db3da97416c2c4bfa152c52de737"
PIN_vendored_rocq_ext_lib="94a663059c9a069f6a5b904fd8c947852b8a90b9"
PIN_vendored_rocq_lsp="a8b7272158f11f16cbe4cbaaff4dd12f06357f11"
PIN_vendored_vsrocq="5b4527ea83e2b6b5b136dcd0a968797583ebd222"

# Tool version requirements (from the workspace's own dev-check-ver scripts).
REQ_ROCQ="9.1.0"          # Rocq Prover (built from vendored source)
REQ_OCAML="5.4.0"         # OCaml compiler (opam switch)
REQ_DUNE="3.21.0"
REQ_OPAM_MIN="2.2.1"
REQ_CLANG_MIN="18.0.0"    # recommended 19.x; cpp2v links against libclang
REQ_CLANG_MAX="22.0.0"    # first unsupported
